{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd webClub-main-/frontend && npm ci",
  "buildCommand": "cd webClub-main-/frontend && npm run build",
  "outputDirectory": "webClub-main-/frontend/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
